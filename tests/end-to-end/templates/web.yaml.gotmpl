test: thing
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: myapp-web
  labels:
    app: myapp-web
spec:
  replicas: 2
  selector:
    matchLabels:
      app: myapp-web
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 0%
      maxSurge: 100%
  template:
    metadata:
      name: myapp-web
      labels:
        app: myapp-web
    spec:
      containers:
        - name: web
          image: docker.io/myapp-web
          resources:
            requests:
              cpu: 100m
      nodeSelector:
        type: user
      priorityClassName: myapp-priority-web
      restartPolicy: Always
      tolerations:
        - effect: NoSchedule
          key: environment
          operator: Equal
          value: production
